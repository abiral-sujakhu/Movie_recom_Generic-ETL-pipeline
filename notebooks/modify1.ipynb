    "# IMDb Rating vs TMDB Rating\n",
    "valid_data = viz_df.dropna(subset=['imdb_rating', 'tmdb_rating'])\n",
    "axes[0, 1].scatter(valid_data['tmdb_rating'], valid_data['imdb_rating'], alpha=0.5, s=30, c='green', edgecolors='black', linewidth=0.5)\n",
